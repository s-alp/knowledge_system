DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
DJANGO_SQLITE_PATH=
VIEWER_TIMEOUT_SECONDS=15
VIEWER_MAX_DOWNLOAD_BYTES=31457280
VIEWER_ARTIFACT_TTL_SECONDS=86400
VIEWER_ALLOWED_SCHEMES=http,https
VIEWER_INTERNAL_URLS_ENABLED=true
VIEWER_INTERNAL_HOST_ALLOWLIST=fileserver.example.local,viewer-demo.internal
VIEWER_INTERNAL_CIDR_ALLOWLIST=10.10.0.0/16,192.168.100.0/24
VIEWER_STEP_ENABLED=true
VIEWER_LOCAL_FILE_ENABLED=false
VIEWER_STORAGE_ROOT=
VIEWER_STEP_STL_TOLERANCE=0.8
VIEWER_STEP_STL_ANGULAR_TOLERANCE=0.4
PDM_API_BASE_URL=
PDM_DRAWING_RESOLVE_PATH_TEMPLATE=/drawings/internals/{drawing_id}/
PDM_REQUEST_TIMEOUT_SECONDS=15
# frontend の静的配布用ビルド値。docker compose up --build で固定される
VITE_API_BASE_URL=/api/v1
# frontend の開発サーバ専用。docker-compose.dev.yml や npm run dev でのみ利用する
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8001
# frontend の静的配布用ビルド値。VIEWER_LOCAL_FILE_ENABLED と合わせて管理する
VITE_LOCAL_FILE_ENABLED=false
