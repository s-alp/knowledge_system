DJANGO_SECRET_KEY=dev-only-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SQLITE_PATH=
DRAWING_METADATA_STORAGE_ROOT=
DRAWING_METADATA_PREVIEW_ASSET_ROOT=
DRAWING_METADATA_PREVIEW_ASSET_BASE_URL=/api/v1/drawing-metadata-preview-assets
DRAWING_METADATA_HANDOFF_MANIFEST=
DRAWING_METADATA_EXTRACTOR_EXECUTABLE=
DRAWING_METADATA_SXNET_DLL_PATH=
DRAWING_METADATA_ICAD_EXECUTABLE=
DRAWING_METADATA_ICAD_STARTUP_WAIT_SECONDS=8
DRAWING_METADATA_ICAD_SHUTDOWN_IF_AUTOSTARTED=true
DRAWING_METADATA_EXTRACTOR_TIMEOUT_SECONDS=60
DRAWING_METADATA_WORKER_POLL_SECONDS=5
DRAWING_METADATA_JOB_LEASE_SECONDS=180
DRAWING_METADATA_WORKER_HEARTBEAT_STALE_SECONDS=30
DRAWING_METADATA_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-3.5-flash
GEMINI_TEMPERATURE=0.0
